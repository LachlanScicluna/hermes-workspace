#!/usr/bin/env node
import { runTelegramNaturalLanguageTaskIntakeCli } from '../scripts/telegram-natural-language-task-intake.mjs'

runTelegramNaturalLanguageTaskIntakeCli().catch((error) => {
  process.stdout.write(`${JSON.stringify({ ok: false, preview_only: true, error: String(error?.message || error) }, null, 2)}\n`)
  process.exitCode = 1
})
